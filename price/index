    // 时段增删（仅最后一条显示删除按钮）
    function addTimeRow(el) {
        var container = el.parentNode;
        var rows = container.querySelectorAll('.time-row');
        if (rows.length === 0) { container.insertBefore(createTimeRow('00:00', ''), el); return; }

        var lastRow = rows[rows.length - 1];
        var lastStart = lastRow.querySelectorAll('.time-input')[0].value;
        var lastEnd = lastRow.querySelectorAll('.time-input')[1].value;

        // 结束时间不能为空
        if (!lastEnd) {
            alert('请先填写上一条时段的结束时间，再添加新时段');
            return;
        }

        // 结束时间必须大于开始时间
        if (lastEnd <= lastStart) {
            alert('结束时间必须大于开始时间，请检查上一条时段');
            return;
        }

        // 如果最后一条结束时间是 23:59，说明已覆盖全天，禁止添加
        if (lastEnd === '23:59') {
            alert('时段已覆盖全天 00:00~23:59，无法继续添加');
            return;
        }

        // 校验连续：每条的开始必须等于上条的结束 + 1 分钟
        for (var i = 0; i < rows.length - 1; i++) {
            var curEnd = rows[i].querySelectorAll('.time-input')[1].value;
            var nextStart = rows[i + 1].querySelectorAll('.time-input')[0].value;
            if (incrementTime(curEnd) !== nextStart) {
                alert('时段区间不连续，请先调整已有时段');
                return;
            }
        }

        // 新行开始时间 = 上一条结束时间 + 1 分钟，结束时间留空让用户填写
        var newStart = incrementTime(lastEnd);

        // 移除上一条（现在变为倒数第二条）的删除按钮
        var oldLastRemove = lastRow.querySelector('.time-remove');
        if (oldLastRemove) oldLastRemove.remove();

        container.insertBefore(createTimeRow(newStart, ''), el);
    }

    function createTimeRow(start, end) {
        var endHtml = end ? 'value="' + end + '"' : 'placeholder="结束时间"';
        var row = document.createElement('div');
        row.className = 'time-row';
        row.innerHTML = '<select class="time-select"><option>谷时</option><option>峰时</option><option selected>平时</option><option>尖时</option><option>深谷</option></select>'
            + '<input class="time-input" type="time" value="' + start + '">'
            + '<span class="time-sep">至</span>'
            + '<input class="time-input" type="time" ' + endHtml + '>'
            + '<span class="time-remove" onclick="removeTimeRow(this)">&times;</span>';
        return row;
    }

    function removeTimeRow(el) {
        var row = el.closest ? el.closest('.time-row') : (el.parentNode.className === 'time-row' ? el.parentNode : null);
        var container = row.parentNode;
        var rows = container.querySelectorAll('.time-row');
        if (rows.length <= 1) {
            alert('至少保留一个时段');
            return;
        }

        container.removeChild(row);

        // 给新的最后一条加上删除按钮
        var remainRows = container.querySelectorAll('.time-row');
        var newLast = remainRows[remainRows.length - 1];
        if (newLast && !newLast.querySelector('.time-remove')) {
            newLast.insertAdjacentHTML('beforeend', '<span class="time-remove" onclick="removeTimeRow(this)">&times;</span>');
        }
    }

    function incrementTime(timeStr) {
        var parts = timeStr.split(':');
        var hour = parseInt(parts[0], 10);
        var minute = parseInt(parts[1], 10);
        minute++;
        if (minute >= 60) { minute = 0; hour++; }
        if (hour >= 24) return '23:59';
        return (hour < 10 ? '0' : '') + hour + ':' + (minute < 10 ? '0' : '') + minute;
    }

    // 时段组增删

    // 时段事件互斥：同一scope value只能被一个时段事件组选中
    function syncTimeGroupScopes(el) {
        var container = el.closest('.time-groups');
        if (!container) return;
        var allCheckboxes = container.querySelectorAll('.time-group-header input[type="checkbox"]');

        // 收集所有被选中的值
        var checkedValues = {};
        allCheckboxes.forEach(function(cb) {
            if (cb.checked) {
                checkedValues[cb.value] = true;
            }
        });

        // 遍历所有checkbox
        allCheckboxes.forEach(function(cb) {
            // 检查同value是否在其他组中被选中
            var checkedElsewhere = false;
            allCheckboxes.forEach(function(other) {
                if (other !== cb && other.value === cb.value && other.checked) {
                    checkedElsewhere = true;
                }
            });
            if (checkedElsewhere) {
                cb.checked = false;   // 取消勾选
                cb.disabled = true;   // 置灰不可选
            } else {
                cb.disabled = false;  // 未被其他组占用，可操作
            }
        });
    }

    function addTimeGroup(containerId) {
        var container = document.getElementById(containerId);
        var groups = container.querySelectorAll('.time-group');
        var num = groups.length + 1;

        // 如果之前只有1组，显示其删除按钮
        if (groups.length === 1) {
            var prevBtn = groups[0].querySelector('.time-group-remove');
            if (prevBtn) prevBtn.style.display = '';
        }

        var div = document.createElement('div');
        div.className = 'time-group';
        div.innerHTML = '<div class="time-group-header">'
            + '<span class="time-group-name">时段事件' + num + '</span>'
            + '<span class="time-group-scope-label">适用范围：</span>'
            + '<label class="time-group-scope-item"><input type="checkbox" value="单一制-不满1千伏" onchange="syncTimeGroupScopes(this)"> 单一制-不满1千伏</label>'
            + '<label class="time-group-scope-item"><input type="checkbox" value="单一制-1-10千伏" onchange="syncTimeGroupScopes(this)"> 单一制-1-10千伏</label>'
            + '<label class="time-group-scope-item"><input type="checkbox" value="单一制-35千伏" onchange="syncTimeGroupScopes(this)"> 单一制-35千伏</label>'
            + '<label class="time-group-scope-item"><input type="checkbox" value="两部制-1-10千伏" onchange="syncTimeGroupScopes(this)"> 两部制-1-10千伏</label>'
            + '<label class="time-group-scope-item"><input type="checkbox" value="两部制-35千伏" onchange="syncTimeGroupScopes(this)"> 两部制-35千伏</label>'
            + '<label class="time-group-scope-item"><input type="checkbox" value="两部制-110千伏" onchange="syncTimeGroupScopes(this)"> 两部制-110千伏</label>'
            + '<label class="time-group-scope-item"><input type="checkbox" value="两部制-220千伏及以上" onchange="syncTimeGroupScopes(this)"> 两部制-220千伏及以上</label>'
            + '<span class="time-group-remove" onclick="removeTimeGroup(this)">删除</span>'
            + '</div>'
            + '<div class="time-group-body">'
            + '<div class="time-add" onclick="addTimeRow(this)">+ 添加时间段</div>'
            + '</div>';
        container.appendChild(div);

        // 同步新组的互斥状态
        var firstCb = div.querySelector('.time-group-header input[type="checkbox"]');
        if (firstCb) syncTimeGroupScopes(firstCb);
    }

    function removeTimeGroup(el) {
        var group = el.closest ? el.closest('.time-group') : el.parentNode.parentNode;
        var container = group.parentNode;
        if (container.querySelectorAll('.time-group').length <= 1) {
            alert('至少保留一个时段组');
            return;
        }
        group.remove();
        // 同步剩余组的互斥状态（被删除组释放的scope应变为可选）
        var remain = container.querySelectorAll('.time-group');
        if (remain.length > 0) {
            var firstCb = remain[0].querySelector('.time-group-header input[type="checkbox"]');
            if (firstCb) syncTimeGroupScopes(firstCb);
        }
        // 只剩1组时隐藏其删除按钮
        if (remain.length === 1) {
            var btn = remain[0].querySelector('.time-group-remove');
            if (btn) btn.style.display = 'none';
        }
    }
