<script>
    function showPage(id) {
        document.getElementById('page-' + id).style.display = 'block';
        document.querySelectorAll('.demo-btn').forEach(b => b.classList.remove('active'));
        var map = {'list':'列表','create':'新增','detail':'编辑','upload':'上传','batch':'发布','history':'历史'};
        document.querySelectorAll('.demo-btn').forEach(b => {
            if (b.textContent.includes(map[id] || '')) b.classList.add('active');
        });
    }
    function showCreateModal() { document.getElementById('createModal').style.display = 'flex'; updateAvailableProvinces(); }
    function hideCreateModal() { document.getElementById('createModal').style.display = 'none'; }

    // 编辑弹窗"保存并发布"：更新对应省份状态为已发布
    function saveAndPublish() {
        // 模拟：编辑弹窗当前展示的是浙江省（demo数据中第一个编辑按钮对应浙江）
        var rows = document.querySelectorAll('#page-list .data-table tbody tr');
        if (rows.length > 0) {
            var row = rows[0]; // 浙江（已发布 → 重新发布也保持已发布）
            // 如果该行是待发布则更新，否则保持已发布
            var badge = row.querySelector('.badge');
            if (badge && badge.textContent !== '已发布') {
                badge.textContent = '已发布';
                badge.className = 'badge badge-published';
                // 禁用发布按钮
                var actionLinks = row.querySelectorAll('.action-link');
                for (var i = 0; i < actionLinks.length; i++) {
                    if (actionLinks[i].textContent.trim() === '发布') {
                        actionLinks[i].className = 'action-link disabled';
                        actionLinks[i].removeAttribute('onclick');
                        break;
                    }
                }
                // 更新发布时间
                var now = new Date();
                var pad = function(n) { return (n < 10 ? '0' : '') + n; };
                var timeStr = now.getFullYear() + '-' + pad(now.getMonth()+1) + '-' + pad(now.getDate())
                    + ' ' + pad(now.getHours()) + ':' + pad(now.getMinutes()) + ':' + pad(now.getSeconds());
                var timeCells = row.querySelectorAll('td');
                if (timeCells.length >= 5) timeCells[4].textContent = timeStr;
            }
        }
        hideModal('modal-detail');
        alert('保存并发布成功！');
    }

    function showUploadModal() {
        document.getElementById('uploadModal').style.display = 'flex';
        currentUploadStep = 1; updateUploadStepUI();
        resetValidation();
    }
    function hideUploadModal() { document.getElementById('uploadModal').style.display = 'none'; }
    var currentUploadStep = 1;
    var validationDone = false;
    var validationResults = {};  // pid -> {pass: true/false, errors: [...]}

    function prevUploadStep() {
        if (currentUploadStep > 1) {
            // 如果从第5步回退，重置完成状态
            if (currentUploadStep === 5) {
                // 保持校验结果不变，仅回退步骤
            }
            currentUploadStep--;
            updateUploadStepUI();
        }
    }

    function nextUploadStep() {
        if (currentUploadStep === 4 && !validationDone) {
            doValidate();
            return;
        }
        if (currentUploadStep === 4 && validationDone) {
            // Check if any failed provinces exist
            var hasFail = false;
            for (var pid in validationResults) {
                if (!validationResults[pid].pass) { hasFail = true; break; }
            }
            if (hasFail) {
                // Ask if user wants to proceed with passing provinces only
                if (!confirm('部分省份未通过校验，确认仅上传通过校验的省份吗？')) return;
            }
            // Proceed to step 5
            currentUploadStep = 5;
            updateUploadStepUI();
            return;
        }
        if (currentUploadStep < 5) { currentUploadStep++; updateUploadStepUI(); }
        else { hideUploadModal(); }
    }

    function doValidate() {
        validationDone = true;
        validationResults = {};
        var rows = document.querySelectorAll('.prow');
        var periodNames = ['尖段', '峰段', '平段', '谷段', '深谷'];

        rows.forEach(function(r) {
            var pid = r.getAttribute('data-pid');
            var province = r.getAttribute('data-province');
            var recordsStr = r.getAttribute('data-records');
            var records = JSON.parse(recordsStr);
            var errors = [];

            // Demo校验：模拟已存在的电价时段记录
            if (province === '上海') {
                errors.push('2026-07月份上海的电价时段记录已存在');
            }

            records.forEach(function(rec) {
                var prices = [rec.jd, rec.fd, rec.pd, rec.gd, rec.sgd];
                for (var j = 0; j < prices.length - 1; j++) {
                    var p1 = parseFloat(prices[j]);
                    var p2 = parseFloat(prices[j+1]);
                    if (!isNaN(p1) && !isNaN(p2)) {
                        if (p1 < p2) {
                            errors.push(rec.usage + '-' + rec.voltage + '：'
                                + periodNames[j] + '(' + p1.toFixed(4) + ') < '
                                + periodNames[j+1] + '(' + p2.toFixed(4) + ')，不满足依次降低');
                        }
                    }
                }
            });

            validationResults[pid] = {
                pass: errors.length === 0,
                name: province,
                errors: errors
            };
        });

        // Update UI - apply province-level validation to all rows in each group
        var passCount = 0, failCount = 0;
        rows.forEach(function(r) {
            var pid = r.getAttribute('data-pid');
            var badge = r.querySelector('.v-badge');
            // Also affect sub-rows of the same province group
            var groupRows = [r].concat([].slice.call(document.querySelectorAll('.prow-rec[data-pid="' + pid + '"]')));
            if (validationResults[pid].pass) {
                badge.className = 'v-badge v-pass';
                badge.textContent = '通过';
                groupRows.forEach(function(tr) { tr.classList.add('v-row-pass'); });
                passCount++;
            } else {
                badge.className = 'v-badge v-fail';
                badge.textContent = '失败';
                groupRows.forEach(function(tr) { tr.classList.add('v-row-fail'); });
                failCount++;
            }
        });

        // Update summary bar
        var summary = document.getElementById('validationSummary');
        summary.style.display = 'block';
        if (failCount === 0) {
            summary.className = 'v-pass-bar';
            summary.style.cssText = summary.style.cssText + 'margin-bottom:16px;padding:12px 16px;border-radius:var(--radius-md);font-size:13px;';
            summary.innerHTML = '<strong style="color:var(--success);">\u2713 全部通过</strong> \u2014 ' + passCount + ' 个省份共 ' + [].reduce.call(rows, function(s, r) {
                return s + JSON.parse(r.getAttribute('data-records')).length;
            }, 0) + ' 条记录均符合电价依次降低规则';
        } else if (passCount > 0) {
            summary.className = 'v-partial-bar';
            summary.style.cssText = summary.style.cssText + 'margin-bottom:16px;padding:12px 16px;border-radius:var(--radius-md);font-size:13px;';
            summary.innerHTML = '<strong style="color:#faad14;">\u26a0 部分通过</strong> \u2014 ' + passCount + ' 个省份通过，<strong style="color:var(--error);">' + failCount + ' 个省份未通过</strong>，可继续上传通过校验的省份';
        } else {
            summary.className = 'v-fail-bar';
            summary.style.cssText = summary.style.cssText + 'margin-bottom:16px;padding:12px 16px;border-radius:var(--radius-md);font-size:13px;';
            summary.innerHTML = '<strong style="color:var(--error);">\u2717 全部未通过</strong> \u2014 请返回修改后重新上传';
        }

        // Show error details
        var details = document.getElementById('validationDetails');
        var detailList = document.getElementById('validationDetailList');
        details.style.display = 'block';
        detailList.innerHTML = '';
        for (var pid in validationResults) {
            if (!validationResults[pid].pass) {
                var item = document.createElement('div');
                item.className = 'v-error-item';
                item.innerHTML = '<strong style="color:var(--error);">' + validationResults[pid].name + '</strong> \u2014 ' + validationResults[pid].errors.length + ' 条错误：<br>';
                validationResults[pid].errors.forEach(function(e) {
                    item.innerHTML += '<span style="color:var(--text-secondary);font-size:12px;">\u00a0\u00a0\u2022 ' + e + '</span><br>';
                });
                detailList.appendChild(item);
            }
        }

        // Update button
        var btn = document.getElementById('uploadNextBtn');
        if (failCount === 0) {
            btn.textContent = '确认上传';
            setTimeout(function() {
                if (confirm('全部通过校验，确认上传？')) {
                    currentUploadStep = 5; updateUploadStepUI();
                }
            }, 300);
        } else if (passCount > 0) {
            btn.textContent = '仅上传通过校验的省份';
        } else {
            btn.textContent = '返回修改';
            btn.onclick = function() { currentUploadStep = 3; validationDone = false; updateUploadStepUI(); };
        }
    }

    function resetValidation() {
        validationDone = false;
        validationResults = {};
        document.querySelectorAll('.prow, .prow-rec').forEach(function(r) {
            r.classList.remove('v-row-pass', 'v-row-fail');
        });
        document.querySelectorAll('.prow').forEach(function(r) {
            var badge = r.querySelector('.v-badge');
            badge.className = 'v-badge v-pending';
            badge.textContent = '待校验';
        });
        document.getElementById('validationSummary').style.display = 'none';
        document.getElementById('validationDetails').style.display = 'none';
    }

    function updateUploadStepUI() {
        for (var i = 1; i <= 5; i++) {
            var el = document.getElementById('uploadStep' + i);
            if (el) el.style.display = (i === currentUploadStep) ? 'block' : 'none';
        }
        // 更新"下一步"按钮
        var btn = document.getElementById('uploadNextBtn');
        if (btn) {
            if (currentUploadStep === 4) {
                if (!validationDone) btn.textContent = '确认上传';
                else btn.textContent = '仅上传通过校验的省份';
            } else if (currentUploadStep === 5) {
                btn.textContent = '完成';
            } else {
                btn.textContent = '下一步';
            }
            btn.onclick = nextUploadStep;
        }
        // 更新"上一步"按钮：第1步显示"取消"，第2-4步显示"上一步"，第5步隐藏
        var prevBtn = document.getElementById('uploadPrevBtn');
        if (prevBtn) {
            if (currentUploadStep === 5) {
                prevBtn.style.display = 'none';
            } else {
                prevBtn.style.display = '';
                if (currentUploadStep === 1) {
                    prevBtn.textContent = '取消';
                    prevBtn.onclick = hideUploadModal;
                } else {
                    prevBtn.textContent = '上一步';
                    prevBtn.onclick = prevUploadStep;
                }
            }
        }
        if (currentUploadStep === 5) { renderUploadResult(); }
    }

    function renderUploadResult() {
        var container = document.getElementById('uploadResult');
        var passCount = 0, failCount = 0, passNames = [], failNames = [];
        for (var pid in validationResults) {
            if (validationResults[pid].pass) { passCount++; passNames.push(validationResults[pid].name); }
            else { failCount++; failNames.push(validationResults[pid].name); }
        }
        var total = passCount + failCount;
        var html = '';
        if (failCount === 0) {
            html += '<div style="font-size:48px;margin-bottom:16px;color:var(--success);">&#10003;</div>';
            html += '<div style="font-size:16px;font-weight:500;color:var(--success);margin-bottom:8px;">上传完成</div>';
            var totalRecs = [].reduce.call(document.querySelectorAll('.prow'), function(s, r) {
                return s + JSON.parse(r.getAttribute('data-records')).length;
            }, 0);
            html += '<div style="font-size:13px;color:var(--text-secondary);">已成功上传 ' + passCount + ' 个省份共 ' + totalRecs + ' 条电价记录，请在列表中查看并发布</div>';
        } else if (failCount > 0 && passCount > 0) {
            html += '<div style="font-size:48px;margin-bottom:16px;color:#faad14;">&#9888;</div>';
            html += '<div style="font-size:16px;font-weight:500;color:#faad14;margin-bottom:8px;">部分上传完成</div>';
            html += '<div style="font-size:13px;color:var(--text-secondary);margin-bottom:16px;">已成功上传 ' + passCount + ' 个省份，' + failCount + ' 个省份因校验未通过被跳过</div>';
            // Show passing provinces
            html += '<div style="text-align:left;margin:0 auto;max-width:400px;padding:12px 16px;background:#f6ffed;border-radius:var(--radius-md);border:1px solid #b7eb8f;margin-bottom:8px;">';
            html += '<div style="font-size:13px;font-weight:500;color:var(--success);margin-bottom:4px;">✓ 已上传的省份：</div>';
            passNames.forEach(function(n) { html += '<span style="font-size:12px;color:var(--text-secondary);">' + n + ' </span>'; });
            html += '</div>';
            // Show failing provinces
            html += '<div style="text-align:left;margin:0 auto;max-width:400px;padding:12px 16px;background:#fff2f0;border-radius:var(--radius-md);border:1px solid #ffccc7;">';
            html += '<div style="font-size:13px;font-weight:500;color:var(--error);margin-bottom:4px;">✗ 未通过的省份：</div>';
            failNames.forEach(function(n) { html += '<span style="font-size:12px;color:var(--text-secondary);">' + n + ' </span>'; });
            html += '<div style="font-size:12px;color:var(--text-secondary);margin-top:4px;">请修正数据后重新上传</div></div>';
        } else {
            html += '<div style="font-size:48px;margin-bottom:16px;color:var(--error);">&#10007;</div>';
            html += '<div style="font-size:16px;font-weight:500;color:var(--error);margin-bottom:8px;">上传失败</div>';
            html += '<div style="font-size:13px;color:var(--text-secondary);margin-bottom:16px;">全部 ' + failCount + ' 个省份均未通过校验</div>';
            html += '<div style="text-align:left;margin:0 auto;max-width:400px;padding:12px 16px;background:#fff2f0;border-radius:var(--radius-md);border:1px solid #ffccc7;">';
            html += '<div style="font-size:13px;font-weight:500;color:var(--error);margin-bottom:4px;">✗ 未通过的省份：</div>';
            failNames.forEach(function(n) { html += '<span style="font-size:12px;color:var(--text-secondary);">' + n + ' </span>'; });
            html += '<div style="font-size:12px;color:var(--text-secondary);margin-top:4px;">请修正数据后重新上传</div></div>';
        }
        container.innerHTML = html;
    }
    function hideHistoryModal() { document.getElementById('historyModal').style.display = 'none'; }
    function showHistoryModal() { document.getElementById('historyModal').style.display = 'flex'; }
    function showModal(id) { document.getElementById(id).style.display = 'flex'; }
    function hideModal(id) { document.getElementById(id).style.display = 'none'; }
    // 已有数据的省份映射（月份 → 省份列表）
    var existingPriceData = {
        '2026-05': ['江苏'],
        '2026-06': ['浙江', '上海', '广东'],
        '2026-07': ['浙江', '广东']
    };

    function updateAvailableProvinces() {
        var monthInput = document.getElementById('createMonth');
        var provSelect = document.getElementById('createProvince');
        if (!monthInput || !provSelect) return;
        var month = monthInput.value;
        var occupied = existingPriceData[month] || [];
        // 遍历所有option，置灰已配置的省份
        for (var i = 0; i < provSelect.options.length; i++) {
            var opt = provSelect.options[i];
            if (opt.value && occupied.indexOf(opt.value) >= 0) {
                opt.disabled = true;
                if (opt.selected) opt.selected = false;
            } else {
                opt.disabled = false;
            }
        }
    }

    function publishRow(el) {
        var row = el.closest('tr');
        var province = row.querySelector('td:first-child').textContent.trim();
        if (confirm('确认发布【' + province + '】的电价配置？')) {
            // 更新状态badge
            row.querySelector('.badge').textContent = '已发布';
            row.querySelector('.badge').className = 'badge badge-published';
            // 禁用发布按钮
            el.className = 'action-link disabled';
            el.removeAttribute('onclick');
            // 更新发布时间
            var now = new Date();
            var pad = function(n) { return (n < 10 ? '0' : '') + n; };
            var timeStr = now.getFullYear() + '-' + pad(now.getMonth()+1) + '-' + pad(now.getDate())
                + ' ' + pad(now.getHours()) + ':' + pad(now.getMinutes()) + ':' + pad(now.getSeconds());
            var timeCells = row.querySelectorAll('td');
            // 发布时间在第5列（索引4）
            if (timeCells.length >= 5) {
                timeCells[4].textContent = timeStr;
            }
            alert('发布成功！');
        }
    }
