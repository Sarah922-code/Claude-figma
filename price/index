<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=1920, initial-scale=1.0">
    <title>星能SaaS - 电价配置管理（省份版）</title>
    <style>
        :root {
            --primary: #F08300;
            --primary-hover: #D97400;
            --primary-bg: #FFF5EB;
            --text-primary: rgba(0,0,0,0.88);
            --text-secondary: rgba(0,0,0,0.65);
            --text-disabled: rgba(0,0,0,0.45);
            --text-muted: #666666;
            --border: #D9D9D9;
            --border-light: #E9E9E9;
            --link: #F08300;
            --link-disabled: #D7D7D7;
            --success: #52c41a;
            --success-bg: #f6ffed;
            --warning: #faad14;
            --warning-bg: #fffbe6;
            --error: #ff4d4f;
            --error-bg: #fff2f0;
            --bg-page: #FBFBFB;
            --bg-white: #FFFFFF;
            --table-header: #FAFAFA;
            --table-row-hover: #FAFAFA;
            --radius-sm: 4px;
            --radius-md: 6px;
            --radius-lg: 8px;
            --shadow: 0 1px 2px rgba(0,0,0,0.05);
            --font: Roboto, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: var(--font); background: var(--bg-page); color: var(--text-primary); font-size: 14px; }
        .app { display: flex; min-height: 1080px; }
        .sidebar { width: 185px; background: var(--bg-white); border-right: 1px solid var(--border-light); flex-shrink: 0; }
        .sidebar-header { height: 56px; display: flex; align-items: center; justify-content: center; border-bottom: 1px solid var(--border-light); }
        .sidebar-logo { font-size: 16px; font-weight: 600; color: var(--primary); }
        .sidebar-nav { padding: 12px 0; }
        .sidebar-item { display: flex; align-items: center; padding: 10px 20px; cursor: pointer; font-size: 14px; color: var(--text-primary); }
        .sidebar-item:hover { background: #FAFAFA; }
        .sidebar-item .icon { margin-right: 8px; width: 16px; text-align: center; }
        .sidebar-item.active { background: var(--primary-bg); color: var(--primary); border-right: 3px solid var(--primary); }
        .sidebar-sub-nav { padding: 4px 0 4px 28px; }
        .sidebar-sub-item { padding: 8px 12px; cursor: pointer; font-size: 13px; color: var(--text-secondary); border-radius: var(--radius-sm); }
        .sidebar-sub-item:hover { color: var(--primary); }
        .sidebar-sub-item.active { color: var(--primary); background: var(--primary-bg); font-weight: 500; }
        .main { flex: 1; display: flex; flex-direction: column; }
        .top-bar { height: 56px; background: var(--bg-white); border-bottom: 1px solid var(--border-light); display: flex; align-items: center; justify-content: space-between; padding: 0 24px; }
        .top-bar-user { color: var(--text-secondary); font-size: 14px; }
        .lang-switch { color: var(--text-secondary); font-size: 14px; cursor: pointer; }
        .content { flex: 1; padding: 24px; }
        .filter-card { background: var(--bg-white); border-radius: var(--radius-lg); box-shadow: var(--shadow); padding: 16px 24px; margin-bottom: 16px; display: flex; align-items: flex-start; gap: 12px; flex-wrap: wrap; }
        .filter-group { display: flex; align-items: center; gap: 8px; }
        .filter-label { color: var(--text-primary); font-size: 13px; white-space: nowrap; }
        .filter-input { height: 32px; border: 1px solid var(--border); border-radius: var(--radius-md); padding: 0 12px; font-size: 14px; color: var(--text-primary); background: var(--bg-white); outline: none; min-width: 100px; }
        .filter-input:focus, .filter-select:focus { border-color: var(--primary); }
        .filter-select { height: 32px; border: 1px solid var(--border); border-radius: var(--radius-md); padding: 0 12px; font-size: 14px; color: var(--text-primary); background: var(--bg-white); outline: none; min-width: 100px; cursor: pointer; }
        .btn { height: 32px; padding: 0 16px; border-radius: var(--radius-md); font-size: 14px; cursor: pointer; border: none; transition: all 0.2s; display: inline-flex; align-items: center; justify-content: center; gap: 4px; white-space: nowrap; }
        .btn-primary { background: var(--primary); color: #fff; }
        .btn-primary:hover { background: var(--primary-hover); }
        .btn-default { background: var(--bg-white); color: var(--text-primary); border: 1px solid var(--border); }
        .btn-default:hover { border-color: var(--primary); color: var(--primary); }
        .btn-outline { background: var(--bg-white); color: var(--primary); border: 1px solid var(--primary); }
        .btn-outline:hover { background: #FFF5EB; }
        .btn-publish { background: var(--primary); color: #fff; height: 32px; padding: 0 20px; border-radius: var(--radius-md); font-size: 14px; border: none; cursor: pointer; }
        .btn-publish:hover { background: var(--primary-hover); }
        .batch-select-all { display: flex; align-items: center; gap: 8px; }
        .table-card { background: var(--bg-white); border-radius: var(--radius-lg); box-shadow: var(--shadow); overflow: hidden; }
        .data-table { width: 100%; border-collapse: collapse; }
        .data-table th { background: var(--table-header); padding: 14px 16px; text-align: left; font-size: 14px; font-weight: 400; color: var(--text-muted); border-bottom: 1px solid var(--border-light); }
        .data-table td { padding: 14px 16px; border-bottom: 1px solid var(--border-light); font-size: 14px; color: var(--text-primary); vertical-align: top; }
        .data-table tbody tr:hover { background: var(--table-row-hover); }
        .badge { display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 12px; }
        .badge-published { background: var(--success-bg); color: var(--success); }
        .badge-pending { background: var(--warning-bg); color: var(--warning); }
        .action-link { color: var(--link); cursor: pointer; margin-right: 4px; }
        .action-link:hover { text-decoration: underline; }
        .action-link.disabled { color: var(--link-disabled); cursor: not-allowed; }
        .action-sep { color: var(--border); margin: 0 2px; }
        .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
        .section-title { font-size: 16px; font-weight: 600; color: var(--text-primary); }
        .month-expired { color: var(--text-disabled); font-style: italic; }
        .history-layout { display: flex; gap: 20px; min-height: 400px; }
        .history-timeline { width: 260px; flex-shrink: 0; border-right: 1px solid var(--border-light); padding-right: 16px; max-height: 450px; overflow-y: auto; }
        .history-item { padding: 12px; border-radius: var(--radius-md); cursor: pointer; margin-bottom: 4px; border: 1px solid var(--border-light); }
        .history-item:hover { border-color: var(--primary); }
        .history-item.active { border-color: var(--primary); background: var(--primary-bg); }
        .history-item-time { font-size: 11px; color: var(--text-secondary); }
        .history-item-op { font-size: 13px; color: var(--text-primary); margin-top: 4px; font-weight: 500; }
        .history-item-user { font-size: 12px; color: var(--text-secondary); margin-top: 2px; }
        .history-detail { flex: 1; overflow-x: auto; }
        .history-detail-title { font-size: 15px; font-weight: 500; color: var(--primary); margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid var(--border-light); }
        .history-detail-table { width: 100%; border-collapse: collapse; }
        .history-detail-table th { background: var(--table-header); padding: 10px 12px; text-align: left; font-size: 13px; font-weight: 500; color: var(--text-muted); }
        .history-detail-table td { padding: 10px 12px; border-bottom: 1px solid var(--border-light); font-size: 13px; }
        .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.45); display: flex; align-items: center; justify-content: center; z-index: 1000; }
        .modal { background: var(--bg-white); border-radius: var(--radius-lg); width: 900px; max-height: 88vh; overflow-y: auto; }
        .modal-sm { width: 560px; }
        .modal-md { width: 720px; }
        .modal-lg { background: var(--bg-white); width: 1100px; }
        .modal-xl { background: var(--bg-white); width: 1300px; }
        .modal-drawer { background: var(--bg-white); width: 1200px; max-height: 92vh; border-radius: var(--radius-lg); display: flex; flex-direction: column; }
        .modal-drawer .modal-body { flex: 1; overflow-y: auto; padding: 24px; }
        .modal-drawer .modal-footer { border-top: 1px solid var(--border-light); padding: 16px 24px; display: flex; justify-content: flex-end; gap: 12px; background: var(--bg-white); border-radius: 0 0 var(--radius-lg) var(--radius-lg); }
        .modal-header { padding: 16px 24px; border-bottom: 1px solid var(--border-light); display: flex; justify-content: space-between; align-items: center; }
        .modal-header h3 { font-size: 16px; font-weight: 500; color: var(--text-primary); }
        .modal-close { cursor: pointer; font-size: 22px; color: var(--text-secondary); width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; border-radius: 50%; }
        .modal-close:hover { background: #f5f5f5; }
        .modal-body { padding: 24px; }
        .modal-footer { padding: 16px 24px; border-top: 1px solid var(--border-light); display: flex; justify-content: flex-end; gap: 8px; }
        .upload-steps { display: flex; margin-bottom: 24px; padding: 0 20px; }
        .step-item { flex: 1; text-align: center; position: relative; }
        .step-line { position: absolute; top: 16px; left: 0; right: 0; height: 2px; background: var(--border-light); z-index: 0; }
        .step-item:first-child .step-line { left: 50%; }
        .step-item:last-child .step-line { right: 50%; }
        .step-item.completed .step-line { background: var(--primary); }
        .step-circle { width: 32px; height: 32px; border-radius: 50%; background: var(--border-light); color: var(--text-secondary); line-height: 32px; margin: 0 auto 8px; position: relative; z-index: 1; font-size: 14px; }
        .step-item.active .step-circle, .step-item.completed .step-circle { background: var(--primary); color: #fff; }
        .step-label { font-size: 12px; color: var(--text-secondary); }
        .step-item.active .step-label, .step-item.completed .step-label { color: var(--primary); }
        .template-card { display: flex; align-items: center; gap: 12px; padding: 14px 16px; background: #FFF9F0; border-radius: var(--radius-md); margin-bottom: 20px; }
        .template-icon { width: 36px; height: 36px; background: var(--primary); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 18px; flex-shrink: 0; }
        .template-info { flex: 1; }
        .template-name { font-size: 14px; font-weight: 500; color: var(--text-primary); }
        .template-desc { font-size: 12px; color: var(--text-secondary); margin-top: 2px; }
        .upload-zone { border: 2px dashed var(--border); border-radius: var(--radius-md); padding: 40px; text-align: center; cursor: pointer; }
        .upload-zone:hover { border-color: var(--primary); background: #FFFBF5; }
        .upload-icon { font-size: 40px; color: var(--border); margin-bottom: 8px; }
        .upload-text { color: var(--text-primary); margin-bottom: 4px; }
        .upload-hint { font-size: 12px; color: var(--text-secondary); }
        .form-row { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; }
        .form-label { font-size: 13px; color: var(--text-primary); width: 90px; text-align: right; flex-shrink: 0; }
        .form-input { height: 32px; border: 1px solid var(--border); border-radius: var(--radius-md); padding: 0 12px; font-size: 14px; color: var(--text-primary); outline: none; flex: 1; }
        .form-input:focus { border-color: var(--primary); }
        .form-select { height: 32px; border: 1px solid var(--border); border-radius: var(--radius-md); padding: 0 12px; font-size: 14px; color: var(--text-primary); background: var(--bg-white); outline: none; cursor: pointer; }
        .dim-fields { background: var(--bg-white); border: 1px solid var(--border-light); border-radius: var(--radius-lg); padding: 20px 24px; margin-bottom: 16px; }
        .history-info-bar { background: var(--bg-white); border: 1px solid var(--border-light); border-radius: var(--radius-lg); padding: 12px 20px; margin-bottom: 16px; display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
        .history-info-item { display: flex; align-items: center; gap: 6px; }
        .history-info-label { font-size: 13px; color: var(--text-secondary); }
        .history-info-value { font-size: 14px; color: var(--text-primary); font-weight: 500; }
        .detail-card { background: var(--bg-white); border-radius: var(--radius-lg); box-shadow: var(--shadow); margin-bottom: 16px; overflow: hidden; }
        .detail-card-header { padding: 12px 24px; border-bottom: 1px solid var(--border-light); font-size: 15px; font-weight: 500; color: var(--primary); display: flex; align-items: center; justify-content: space-between; }
        .price-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; padding: 20px 24px; }
        .price-card { border-radius: var(--radius-md); padding: 16px; }
        .price-card.grid { background: #FFF9F0; border: 1px solid #FFE4B5; }
        .price-card.to-user { background: #F0F7FF; border: 1px solid #B3D9FF; }
        .price-card.star { background: #F6FFED; border: 1px solid #B7EB8F; }
        .price-card-title { font-size: 14px; font-weight: 500; color: var(--text-primary); margin-bottom: 12px; }
        .price-card-unit { font-size: 12px; color: var(--text-secondary); font-weight: normal; }
        .price-inputs { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; }
        .price-input-item { text-align: center; }
        .price-input-item label { display: block; font-size: 12px; color: var(--text-secondary); margin-bottom: 6px; }
        .price-input-item input { width: 100%; height: 32px; border: 1px solid var(--border); border-radius: var(--radius-md); text-align: center; font-size: 14px; color: var(--text-primary); outline: none; }
        .price-input-item input:focus { border-color: var(--primary); }
        .time-section { padding: 20px 24px; }
        .time-row { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
        .time-select { height: 32px; width: 90px; border: 1px solid var(--border); border-radius: var(--radius-md); padding: 0 8px; font-size: 13px; color: var(--text-primary); background: var(--bg-white); outline: none; cursor: pointer; }
        .time-input { height: 32px; width: 80px; border: 1px solid var(--border); border-radius: var(--radius-md); padding: 0 8px; font-size: 13px; color: var(--text-primary); text-align: center; outline: none; }
.time-input[type="time"] { width: 100px; cursor: pointer; }
.time-input[type="time"]::-webkit-calendar-picker-indicator { cursor: pointer; opacity: 0.6; }
        .time-sep { color: var(--text-secondary); font-size: 13px; }
        .time-remove { cursor: pointer; color: var(--text-disabled); font-size: 16px; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; border-radius: 50%; }
        .time-remove:hover { color: var(--error); background: #fff2f0; }
        .time-add { display: flex; align-items: center; justify-content: center; gap: 4px; width: 100%; height: 36px; border: 1px dashed var(--border); border-radius: var(--radius-md); background: #FAFAFA; cursor: pointer; color: var(--text-secondary); font-size: 13px; margin-top: 8px; }
        .time-add:hover { border-color: var(--primary); color: var(--primary); }
        .preview-table { max-height: 280px; overflow-y: auto; border: 1px solid var(--border-light); border-radius: var(--radius-sm); }
        .preview-table table { width: 100%; font-size: 12px; border-collapse: collapse; }
        .preview-table th { background: var(--table-header); padding: 8px; text-align: left; font-weight: 500; position: sticky; top: 0; }
        .preview-table td { padding: 8px; border-bottom: 1px solid var(--border-light); }
        .page-view { display: none; }
        .page-view.active { display: block; }
        .demo-nav { position: fixed; bottom: 16px; right: 16px; z-index: 999; display: flex; gap: 8px; }
        .demo-nav .btn { box-shadow: 0 2px 8px rgba(0,0,0,0.15); }
        .demo-btn { height: 28px; padding: 0 12px; font-size: 12px; border-radius: var(--radius-sm); background: var(--bg-white); border: 1px solid var(--border); color: var(--text-primary); cursor: pointer; }
        .demo-btn.active { background: var(--primary); color: #fff; border-color: var(--primary); }
        .v-badge { display:inline-block; padding:2px 8px; border-radius:10px; font-size:11px; white-space:nowrap; }
        .v-pending { background:#f5f5f5; color:#999; }
        .v-pass { background:var(--success-bg); color:var(--success); }
        .v-fail { background:var(--error-bg); color:var(--error); }
        .v-row-pass { background:#f6ffed !important; }
        .v-row-fail { background:#fff2f0 !important; }
        .v-row-pass td { border-bottom-color:#b7eb8f !important; }
        .v-row-fail td { border-bottom-color:#ffccc7 !important; }
        .v-pass-bar { background:#f6ffed; border:1px solid #b7eb8f; }
        .v-partial-bar { background:#fffbe6; border:1px solid #ffe58f; }
        .v-fail-bar { background:#fff2f0; border:1px solid #ffccc7; }
        .v-error-item { padding:8px 12px; border-radius:var(--radius-sm); margin-bottom:4px; font-size:13px; background:#fff2f0; border:1px solid #ffccc7; }
        .grid-6 { display: grid; grid-template-columns: repeat(6, 1fr); gap: 12px; }
        .grid-6 .form-group label { display: block; font-size: 12px; color: var(--text-secondary); margin-bottom: 4px; }
        .grid-6 .form-group input { width: 100%; height: 32px; border: 1px solid var(--border); border-radius: var(--radius-md); padding: 0 10px; font-size: 13px; color: var(--text-primary); }
        .grid-6 .form-group input[disabled] { background: #FAFAFA; color: var(--text-secondary); }
        .dim-title { font-size: 14px; font-weight: 500; color: var(--text-primary); margin-bottom: 12px; }
        .section-title { font-size: 15px; font-weight: 500; color: var(--primary); margin-bottom: 12px; }
        .price-section { margin-bottom: 16px; }
        .price-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
        .sub-table { width: 100%; border: 1px solid var(--border-light); border-radius: var(--radius-md); margin: 8px 0; }
        .sub-table th { background: var(--table-header); padding: 8px 12px; text-align: left; font-size: 12px; font-weight: 500; color: var(--text-muted); border-bottom: 1px solid var(--border-light); }
        .sub-table td { padding: 8px 12px; border-bottom: 1px solid var(--border-light); font-size: 13px; color: var(--text-primary); }
        .sub-table tr:last-child td { border-bottom: none; }
        .sub-table tr:hover { background: var(--table-row-hover); }
    
.time-groups { display: flex; flex-direction: column; gap: 12px; }
.time-group { border: 1px solid var(--border-light); border-radius: var(--radius-md); background: var(--bg-white); }
.time-group-header { display: flex; align-items: center; gap: 8px; padding: 10px 16px; background: #FAFAFA; border-bottom: 1px solid var(--border-light); border-radius: var(--radius-md) var(--radius-md) 0 0; flex-wrap: wrap; }
.time-group-name { font-size: 14px; font-weight: 500; color: var(--primary); min-width: 44px; }
.time-group-scope-label { font-size: 12px; color: var(--text-secondary); margin-left: 8px; }
.time-group-scope-item { display: inline-flex; align-items: center; gap: 3px; font-size: 12px; color: var(--text-secondary); cursor: pointer; padding: 2px 6px; border-radius: 4px; }
.time-group-scope-item:hover { background: var(--primary-bg); }
.time-group-scope-item input { cursor: pointer; }
.time-group-scope-item input:disabled { cursor: not-allowed; opacity: 0.4; }
.time-group-body { padding: 12px 16px; }
.time-group-remove { font-size: 12px; color: var(--error); cursor: pointer; margin-left: auto; padding: 2px 8px; border-radius: 4px; }
.time-group-remove:hover { background: var(--error-bg); }
</style>
</head>
<body>
<div class="app">
    <aside class="sidebar">
        <div class="sidebar-header"><span class="sidebar-logo">&#9889; 星能SaaS</span></div>
        <nav class="sidebar-nav">
            <div class="sidebar-item active"><span class="icon"></span>研发配置</div>
            <div class="sidebar-sub-nav">
                <div class="sidebar-sub-item active">电价时段发布</div>
            </div>
        </nav>
    </aside>
    <div class="main">
        <header class="top-bar">
            <div class="top-bar-user">运营端：孙香</div>
            <div><span class="lang-switch">简体中文</span></div>
        </header>
        <div class="content">
            <!-- ===== LIST PAGE ===== -->
            <div id="page-list" class="page-view active">
                <!-- Filters: 省份 + 状态 + 月份 -->
                <div class="filter-card">
                    <div class="filter-group">
                        <span class="filter-label">省份：</span>
                        <select class="filter-select" style="width:120px;">
                            <option>全部</option><option>浙江</option><option>上海</option><option>江苏</option>
                            <option>广东</option><option>北京</option><option>四川</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <span class="filter-label">状态：</span>
                        <select class="filter-select" style="width:110px;">
                            <option>全部</option><option>已发布</option><option>待发布</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <span class="filter-label">月份：</span>
                        <input type="month" class="filter-input" style="width:140px;" value="2026-06">
                    </div>
                    <div class="filter-group">
                        <button class="btn btn-primary">查 询</button>
                        <button class="btn btn-default">重 置</button>
                    </div>
                </div>
                <!-- Title + Action buttons row -->
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
                    <div style="font-size:16px;font-weight:600;color:var(--text-primary);">电价时段列表</div>
                    <div style="display:flex;gap:8px;">
                    <button class="btn btn-primary" onclick="showCreateModal()">新增电价时段</button>
                    <button class="btn btn-primary" onclick="showUploadModal()">批量上传</button>
                    <button class="btn btn-primary" onclick="showModal('batchModal')">批量发布</button>
                    </div>
                </div>
                <!-- Table: 省份聚合（简化版 - 仅展示省份级别） -->
                <div class="table-card">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th style="width:120px;">省份</th>
                                <th style="width:100px;">月份</th>
                                <th style="width:100px;">状态</th>
                                <th style="width:170px;">创建时间</th>
                                <th style="width:170px;">发布时间</th>
                                <th style="width:200px;">操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- 已发布 -->
                            <tr>
